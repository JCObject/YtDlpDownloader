<Window x:Class="YtDlpDownloader.PrimaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YtDlp Downloader"
        Icon="Assets/app.ico"
        Height="840"
        MinHeight="740"
        Width="1280"
        MinWidth="1060"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="112" />
            <RowDefinition Height="178" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{Binding Text[HeaderSteps]}"
                       FontWeight="SemiBold"
                       Foreground="#475569"
                       Margin="0,0,0,8" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="128" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         IsEnabled="{Binding CanEditInputs}"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding Text[TooltipUrl]}"
                         FontSize="15" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeCommand}"
                        Content="{Binding AnalyzeButtonText}" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="{Binding Text[GroupVideoInfo]}">
                        <StackPanel>
                            <Border Height="180"
                                    Background="#E7EBF0"
                                    BorderBrush="#D9E0EA"
                                    BorderThickness="1"
                                    Margin="0,0,0,10">
                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       TextWrapping="Wrap"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding Author}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Duration}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SourceUrl}" Foreground="#475569" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{Binding Text[GroupComponents]}">
                        <StackPanel>
                            <TextBlock Text="{Binding ComponentStatus}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Command="{Binding RefreshComponentsCommand}" Content="{Binding Text[ButtonRefresh]}" />
                                <Button Margin="8,0,0,0" Command="{Binding RepairComponentsCommand}" Content="{Binding Text[ButtonRepair]}" />
                                <Button Margin="8,0,0,0" Command="{Binding UpdateCoreCommand}" Content="{Binding Text[ButtonUpdateCore]}" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{Binding Text[GroupSave]}">
                        <Grid IsEnabled="{Binding CanEditInputs}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Text[LabelSaveDirectory]}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" Command="{Binding BrowseDirectoryCommand}" Content="{Binding Text[ButtonBrowse]}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[LabelFileName]}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding OutputFileName, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding OptionsHint}" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,8" />
                <TabControl Grid.Row="1" IsEnabled="{Binding CanEditInputs}" SelectedIndex="{Binding SelectedTabIndex}">
                    <TabItem Header="{Binding Text[TabSimple]}">
                        <DataGrid Margin="8" ItemsSource="{Binding SimpleFormats}" SelectedItem="{Binding SelectedSimpleFormat}" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="SimpleOptionColumn" Header="选项" Binding="{Binding DisplayName}" Width="180" />
                                <DataGridTextColumn x:Name="SimpleKindColumn" Header="类型" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn x:Name="SimpleResolutionColumn" Header="清晰度" Binding="{Binding Resolution}" Width="110" />
                                <DataGridTextColumn x:Name="SimpleFormatColumn" Header="格式" Binding="{Binding Extension}" Width="80" />
                                <DataGridTextColumn x:Name="SimpleSummaryColumn" Header="说明" Binding="{Binding Summary}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{Binding Text[TabAdvanced]}">
                        <DataGrid Margin="8" ItemsSource="{Binding AdvancedFormats}" SelectedItem="{Binding SelectedAdvancedFormat}" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="format_id" Binding="{Binding FormatId}" Width="90" />
                                <DataGridTextColumn x:Name="AdvancedResolutionColumn" Header="清晰度" Binding="{Binding Resolution}" Width="105" />
                                <DataGridTextColumn x:Name="AdvancedKindColumn" Header="类型" Binding="{Binding Kind}" Width="78" />
                                <DataGridTextColumn x:Name="AdvancedFormatColumn" Header="格式" Binding="{Binding Extension}" Width="70" />
                                <DataGridTextColumn x:Name="AdvancedVideoCodecColumn" Header="视频编码" Binding="{Binding VideoCodec}" Width="150" />
                                <DataGridTextColumn x:Name="AdvancedAudioCodecColumn" Header="音频编码" Binding="{Binding AudioCodec}" Width="140" />
                                <DataGridTextColumn Header="FPS" Binding="{Binding Fps}" Width="60" />
                                <DataGridTextColumn x:Name="AdvancedSizeColumn" Header="大小" Binding="{Binding FileSizeText}" Width="85" />
                                <DataGridTextColumn x:Name="AdvancedExpressionColumn" Header="表达式" Binding="{Binding FormatSelector}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{Binding Text[TabSettings]}">
                        <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Text[SettingsLanguage]}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="160" HorizontalAlignment="Left" ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguageOption}" ToolTip="{Binding Text[TooltipLanguage]}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsMergeFormat]}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,8,0,0" ItemsSource="{Binding MergeOutputFormats}" SelectedItem="{Binding MergeOutputFormat}" ToolTip="{Binding Text[TooltipMergeFormat]}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsCookiesSource]}" />
                                <ComboBox Grid.Row="2" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,8,0,0" ItemsSource="{Binding CookieSources}" SelectedItem="{Binding CookiesSource}" ToolTip="{Binding Text[TooltipCookiesSource]}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsCookiesFile]}" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="{Binding CookiesPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipCookiesFile]}" />
                                <Button Grid.Row="3" Grid.Column="2" Margin="8,8,0,0" Command="{Binding BrowseCookiesCommand}" Content="{Binding Text[ButtonBrowse]}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsProxy]}" />
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding Proxy, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipProxy]}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Text="{Binding Text[SettingsExtras]}" />
                                <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox IsChecked="{Binding DownloadSubtitles}" Content="{Binding Text[SettingsSubtitleFile]}" VerticalAlignment="Center" ToolTip="{Binding Text[TooltipSubtitleFile]}" />
                                    <CheckBox IsChecked="{Binding DownloadAutoSubtitles}" Content="{Binding Text[SettingsAutoSubtitle]}" VerticalAlignment="Center" Margin="16,0,0,0" ToolTip="{Binding Text[TooltipAutoSubtitle]}" />
                                    <CheckBox IsChecked="{Binding DownloadThumbnail}" Content="{Binding Text[SettingsThumbnail]}" VerticalAlignment="Center" Margin="16,0,0,0" ToolTip="{Binding Text[TooltipThumbnail]}" />
                                </StackPanel>
                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsSubtitleLanguages]}" />
                                <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding SubtitleLanguages, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipSubtitleLanguages]}" />
                                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsFileConflict]}" />
                                <ComboBox Grid.Row="7" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,8,0,0" ItemsSource="{Binding FileConflictPolicies}" SelectedItem="{Binding SelectedFileConflictPolicy}" ToolTip="{Binding Text[TooltipFileConflict]}" />
                                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsRateLimit]}" />
                                <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding RateLimit, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipRateLimit]}" />
                                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsRetryCount]}" />
                                <TextBox Grid.Row="9" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipRetryCount]}" />
                                <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding Text[SettingsConcurrentFragments]}" />
                                <TextBox Grid.Row="10" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" Text="{Binding ConcurrentFragments, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipConcurrentFragments]}" />
                                <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Top" Text="{Binding Text[SettingsExtraArgs]}" />
                                <TextBox Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" MinHeight="72" Margin="0,8,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ExtraArgumentsText, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text[TooltipExtraArgs]}" />
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" Background="White" BorderBrush="#D9E0EA" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="132" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Stage}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PrimaryActionSummary}" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                    <ProgressBar Height="14" Minimum="0" Maximum="100" Value="{Binding CurrentTask.Progress}" Margin="0,8,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding OpenFolderCommand}" Content="{Binding Text[ButtonOpenFolder]}" Margin="8,0,0,0" />
                <Button Grid.Column="3" Command="{Binding OpenFileCommand}" Content="{Binding Text[ButtonOpenFile]}" Margin="8,0,0,0" />
                <Button Grid.Column="4" Command="{Binding CancelDownloadCommand}" Content="{Binding Text[ButtonCancelDownload]}" Margin="8,0,0,0" />
                <Button Grid.Column="5" Command="{Binding DownloadCommand}" Content="{Binding Text[ButtonStartDownload]}" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <GroupBox Grid.Row="3" Header="{Binding Text[GroupLog]}" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                    <Button Command="{Binding CopyLogCommand}" Content="{Binding Text[ButtonCopyLog]}" />
                    <Button Command="{Binding ClearLogCommand}" Content="{Binding Text[ButtonClear]}" Margin="8,0,0,0" />
                </StackPanel>
                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Text="{Binding LogText}"
                         TextChanged="LogBox_TextChanged"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="White"
                         FontFamily="Consolas"
                         FontSize="12" />
            </Grid>
        </GroupBox>
    </Grid>
</Window>

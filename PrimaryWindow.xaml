<Window x:Class="YtDlpDownloader.PrimaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YtDlp Downloader"
        Icon="Assets/app.ico"
        Height="840"
        MinHeight="740"
        Width="1280"
        MinWidth="1060"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="112" />
            <RowDefinition Height="178" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="1 输入链接  ->  2 选择清晰度  ->  3 开始下载"
                       FontWeight="SemiBold"
                       Foreground="#475569"
                       Margin="0,0,0,8" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="128" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         IsEnabled="{Binding CanEditInputs}"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="视频 URL"
                         FontSize="15" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Command="{Binding AnalyzeCommand}"
                        Content="{Binding AnalyzeButtonText}" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="视频信息">
                        <StackPanel>
                            <Border Height="180"
                                    Background="#E7EBF0"
                                    BorderBrush="#D9E0EA"
                                    BorderThickness="1"
                                    Margin="0,0,0,10">
                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       TextWrapping="Wrap"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding Author}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Duration}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SourceUrl}" Foreground="#475569" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="组件状态">
                        <StackPanel>
                            <TextBlock Text="{Binding ComponentStatus}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Command="{Binding RefreshComponentsCommand}" Content="刷新" />
                                <Button Margin="8,0,0,0" Command="{Binding RepairComponentsCommand}" Content="修复缺失" />
                                <Button Margin="8,0,0,0" Command="{Binding UpdateCoreCommand}" Content="更新核心" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="保存设置">
                        <Grid IsEnabled="{Binding CanEditInputs}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="保存目录" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" Command="{Binding BrowseDirectoryCommand}" Content="选择" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="文件名" />
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding OutputFileName, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding OptionsHint}" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,8" />
                <TabControl Grid.Row="1" IsEnabled="{Binding CanEditInputs}" SelectedIndex="{Binding SelectedTabIndex}">
                    <TabItem Header="简单下载">
                        <DataGrid Margin="8" ItemsSource="{Binding SimpleFormats}" SelectedItem="{Binding SelectedSimpleFormat}" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="选项" Binding="{Binding DisplayName}" Width="180" />
                                <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="清晰度" Binding="{Binding Resolution}" Width="110" />
                                <DataGridTextColumn Header="格式" Binding="{Binding Extension}" Width="80" />
                                <DataGridTextColumn Header="说明" Binding="{Binding Summary}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="高级格式">
                        <DataGrid Margin="8" ItemsSource="{Binding AdvancedFormats}" SelectedItem="{Binding SelectedAdvancedFormat}" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="format_id" Binding="{Binding FormatId}" Width="90" />
                                <DataGridTextColumn Header="清晰度" Binding="{Binding Resolution}" Width="105" />
                                <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="78" />
                                <DataGridTextColumn Header="格式" Binding="{Binding Extension}" Width="70" />
                                <DataGridTextColumn Header="视频编码" Binding="{Binding VideoCodec}" Width="150" />
                                <DataGridTextColumn Header="音频编码" Binding="{Binding AudioCodec}" Width="140" />
                                <DataGridTextColumn Header="FPS" Binding="{Binding Fps}" Width="60" />
                                <DataGridTextColumn Header="大小" Binding="{Binding FileSizeText}" Width="85" />
                                <DataGridTextColumn Header="表达式" Binding="{Binding FormatSelector}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="下载设置">
                        <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="合并格式" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="160" HorizontalAlignment="Left" ItemsSource="{Binding MergeOutputFormats}" SelectedItem="{Binding MergeOutputFormat}" ToolTip="mp4 兼容性最好；mkv 更包容；auto 交给 yt-dlp 决定。" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="cookies 来源" />
                                <ComboBox Grid.Row="1" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,8,0,0" ItemsSource="{Binding CookieSources}" SelectedItem="{Binding CookiesSource}" ToolTip="B站 412、YouTube 登录验证时，推荐先选择 Chrome 或 Edge。浏览器读取失败时再选择 cookies.txt 文件。" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="cookies 文件" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="{Binding CookiesPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="仅 cookies 来源选择 cookies.txt 时使用。可用 Get cookies.txt LOCALLY 从浏览器导出。" />
                                <Button Grid.Row="2" Grid.Column="2" Margin="8,8,0,0" Command="{Binding BrowseCookiesCommand}" Content="选择" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="代理" />
                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding Proxy, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 http://127.0.0.1:7890；能直接访问视频网站就留空。" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Text="附加内容" />
                                <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox IsChecked="{Binding DownloadSubtitles}" Content="字幕文件" VerticalAlignment="Center" ToolTip="下载作者上传的字幕，通常会生成额外字幕文件。" />
                                    <CheckBox IsChecked="{Binding DownloadAutoSubtitles}" Content="自动字幕" VerticalAlignment="Center" Margin="16,0,0,0" ToolTip="下载自动生成字幕，可能会生成额外字幕文件。" />
                                    <CheckBox IsChecked="{Binding DownloadThumbnail}" Content="封面图片" VerticalAlignment="Center" Margin="16,0,0,0" ToolTip="额外下载视频封面图片。" />
                                </StackPanel>
                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="字幕语言" />
                                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding SubtitleLanguages, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 zh-Hans,zh-CN,en；填 all 表示所有字幕。" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="文件冲突" />
                                <ComboBox Grid.Row="6" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,8,0,0" ItemsSource="{Binding FileConflictPolicies}" SelectedItem="{Binding SelectedFileConflictPolicy}" ToolTip="推荐自动改名，避免覆盖已有文件。" />
                                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="限速" />
                                <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Text="{Binding RateLimit, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 2M、500K；留空表示不限速。" />
                                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="重试次数" />
                                <TextBox Grid.Row="8" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" ToolTip="网络失败时自动重试次数。" />
                                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="并发分片数" />
                                <TextBox Grid.Row="9" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0" Text="{Binding ConcurrentFragments, UpdateSourceTrigger=PropertyChanged}" ToolTip="默认 5。提高部分分片视频速度；网络不稳定时调低，范围 1-16。" />
                                <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Top" Text="高级参数" />
                                <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" MinHeight="72" Margin="0,8,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding ExtraArgumentsText, UpdateSourceTrigger=PropertyChanged}" ToolTip="手动追加 yt-dlp 参数。普通用户建议留空。" />
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" Background="White" BorderBrush="#D9E0EA" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="132" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Stage}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PrimaryActionSummary}" Foreground="#64748B" TextTrimming="CharacterEllipsis" />
                    <ProgressBar Height="14" Minimum="0" Maximum="100" Value="{Binding CurrentTask.Progress}" Margin="0,8,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding OpenFolderCommand}" Content="打开目录" Margin="8,0,0,0" />
                <Button Grid.Column="3" Command="{Binding OpenFileCommand}" Content="打开文件" Margin="8,0,0,0" />
                <Button Grid.Column="4" Command="{Binding CancelDownloadCommand}" Content="取消下载" Margin="8,0,0,0" />
                <Button Grid.Column="5" Command="{Binding DownloadCommand}" Content="开始下载" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <GroupBox Grid.Row="3" Header="日志" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                    <Button Command="{Binding CopyLogCommand}" Content="复制日志" />
                    <Button Command="{Binding ClearLogCommand}" Content="清空" Margin="8,0,0,0" />
                </StackPanel>
                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Text="{Binding LogText}"
                         TextChanged="LogBox_TextChanged"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="White"
                         FontFamily="Consolas"
                         FontSize="12" />
            </Grid>
        </GroupBox>
    </Grid>
</Window>
